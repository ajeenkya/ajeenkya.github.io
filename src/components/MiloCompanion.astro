---
const animations = {
  idle:     '/milo/idle.lottie',
  wink:     '/milo/wink.lottie',
  excited:  '/milo/excited.lottie',
  typing:   '/milo/typing.lottie',
  crazy:    '/milo/crazy.lottie',
  heart:    '/milo/heart.lottie',
  laughing: '/milo/laughing.lottie',
};
---
<div
  id="milo-companion"
  class="milo-companion"
  role="img"
  aria-label="Milo, a friendly little pixie companion"
  data-anims={JSON.stringify(animations)}
>
  <div class="milo-shadow" aria-hidden="true"></div>
  <canvas id="milo-canvas" width="128" height="128"></canvas>
  <span class="milo-hint" aria-hidden="true">hi</span>
</div>
<canvas id="milo-sparkles" aria-hidden="true"></canvas>

<style>
  .milo-companion {
    position: fixed;
    left: 0;
    top: 0;
    width: 72px;
    height: 72px;
    margin-left: -36px;
    margin-top: -36px;
    z-index: 40;
    pointer-events: auto;
    cursor: pointer;
    transform: translate3d(0, 0, 0);
    will-change: transform;
    filter: drop-shadow(0 6px 18px rgba(34, 211, 238, 0.22));
    transition: filter 220ms ease;
  }

  @media (max-width: 640px) {
    .milo-companion { width: 56px; height: 56px; margin-left: -28px; margin-top: -28px; }
  }

  .milo-companion canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  .milo-shadow {
    position: absolute;
    inset: -22% -22% -22% -22%;
    border-radius: 9999px;
    background: radial-gradient(closest-side, rgba(34,211,238,0.28), rgba(34,211,238,0) 70%);
    opacity: 0.9;
    pointer-events: none;
    animation: milo-breathe 3.6s ease-in-out infinite;
  }

  .milo-hint {
    position: absolute;
    left: -36px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(186, 230, 253, 0.8);
    opacity: 0;
    transition: opacity 240ms ease, transform 240ms ease;
    pointer-events: none;
    white-space: nowrap;
  }

  .milo-companion:hover .milo-hint { opacity: 1; transform: translate(-4px, -50%); }

  #milo-sparkles {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: 39;
  }

  @keyframes milo-breathe {
    0%, 100% { transform: scale(0.92); opacity: 0.55; }
    50%      { transform: scale(1.10); opacity: 0.95; }
  }

  @media (prefers-reduced-motion: reduce) {
    .milo-shadow { animation: none; }
    .milo-companion { transition: none; }
    #milo-sparkles { display: none; }
  }
</style>

<script type="module">
  import { DotLottie } from 'https://esm.sh/@lottiefiles/dotlottie-web@0.40.0';

  const el = document.getElementById('milo-companion');
  const canvas = document.getElementById('milo-canvas');
  const sparkleCanvas = document.getElementById('milo-sparkles');
  if (!el || !canvas) { /* bail */ } else {
    const anims = JSON.parse(el.dataset.anims);
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let player = new DotLottie({ canvas, src: anims.idle, loop: true, autoplay: true });

    let currentKey = 'idle';
    let switching = false;
    function swap(key) {
      if (!anims[key] || key === currentKey || switching) return;
      switching = true;
      currentKey = key;
      pulseScale = 1.22;
      try {
        player.load({ src: anims[key], loop: true, autoplay: true });
      } catch (e) {
        try { player.destroy(); } catch {}
        player = new DotLottie({ canvas, src: anims[key], loop: true, autoplay: true });
      }
      setTimeout(() => { switching = false; }, 320);
    }

    // ---- pixie motion model ----
    // Two layers combined:
    //  (a) anchor: a "home" position relative to the viewport that gently
    //      drifts in a figure-8 around the right side; scroll velocity tugs
    //      it like a kite tail.
    //  (b) wing-flutter: high-frequency tiny noise on top, so even when
    //      stationary, Milo never sits still.
    const isSmall = window.matchMedia('(max-width: 640px)').matches;
    const edgePad = isSmall ? 44 : 64;

    let vw = window.innerWidth;
    let vh = window.innerHeight;
    let anchorX = vw - edgePad;
    let anchorY = vh * 0.5;

    // current rendered position (what we lerp toward the anchor)
    let curX = anchorX;
    let curY = anchorY;

    // wing-flutter offsets (small fast osc)
    let flutterPhase = Math.random() * Math.PI * 2;

    // figure-8 idle drift (slow)
    let driftT = Math.random() * 1000;

    // scroll-velocity lag and tilt
    let scrollVel = 0;
    let lastScroll = window.scrollY;
    let tilt = 0;
    let targetTilt = 0;
    let pulseScale = 1; // decays back to 1

    // pointer attraction (gentle approach, never overlap)
    let pointerX = -9999, pointerY = -9999;
    let pointerActive = false;
    window.addEventListener('pointermove', (e) => {
      pointerX = e.clientX; pointerY = e.clientY;
      pointerActive = true;
    }, { passive: true });
    window.addEventListener('pointerleave', () => { pointerActive = false; });

    function recompAnchor() {
      vw = window.innerWidth;
      vh = window.innerHeight;
      anchorX = vw - edgePad;
      anchorY = vh * 0.5;
    }
    window.addEventListener('resize', recompAnchor, { passive: true });

    function onScroll() {
      const now = window.scrollY;
      scrollVel = now - lastScroll;
      lastScroll = now;
      targetTilt = Math.max(-16, Math.min(16, scrollVel * 0.5));
    }
    window.addEventListener('scroll', onScroll, { passive: true });

    // ---- sparkle trail (canvas) ----
    let sctx = null;
    const sparkles = [];
    function sizeSparkles() {
      if (!sparkleCanvas) return;
      const dpr = Math.min(2, window.devicePixelRatio || 1);
      sparkleCanvas.width = Math.floor(window.innerWidth * dpr);
      sparkleCanvas.height = Math.floor(window.innerHeight * dpr);
      sparkleCanvas.style.width = window.innerWidth + 'px';
      sparkleCanvas.style.height = window.innerHeight + 'px';
      sctx = sparkleCanvas.getContext('2d');
      sctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    if (sparkleCanvas) {
      sizeSparkles();
      window.addEventListener('resize', sizeSparkles, { passive: true });
    }

    let lastSparkleAt = 0;
    function emitSparkle(x, y, speed) {
      const now = performance.now();
      // throttle: more sparkles when moving fast
      const interval = Math.max(36, 160 - speed * 12);
      if (now - lastSparkleAt < interval) return;
      lastSparkleAt = now;
      const count = 1 + Math.floor(Math.min(2, speed * 0.4));
      for (let i = 0; i < count; i++) {
        sparkles.push({
          x: x + (Math.random() - 0.5) * 14,
          y: y + (Math.random() - 0.5) * 14,
          vx: (Math.random() - 0.5) * 0.4,
          vy: (Math.random() - 0.5) * 0.4 + 0.15, // gently drift down
          life: 0,
          maxLife: 600 + Math.random() * 500, // ms
          size: 1.2 + Math.random() * 1.6,
          hue: 188 + Math.random() * 22, // cyan→teal range
        });
      }
    }

    function renderSparkles(dt) {
      if (!sctx) return;
      sctx.clearRect(0, 0, window.innerWidth, window.innerHeight);
      for (let i = sparkles.length - 1; i >= 0; i--) {
        const s = sparkles[i];
        s.life += dt;
        if (s.life >= s.maxLife) { sparkles.splice(i, 1); continue; }
        s.x += s.vx;
        s.y += s.vy;
        const t = s.life / s.maxLife;
        const alpha = (1 - t) * 0.55;
        const r = s.size * (1 - t * 0.4);
        sctx.beginPath();
        sctx.arc(s.x, s.y, r, 0, Math.PI * 2);
        sctx.fillStyle = `hsla(${s.hue}, 90%, 70%, ${alpha})`;
        sctx.shadowBlur = 8;
        sctx.shadowColor = `hsla(${s.hue}, 90%, 70%, ${alpha * 0.8})`;
        sctx.fill();
      }
      sctx.shadowBlur = 0;
    }

    // ---- main loop ----
    let prevTime = performance.now();
    let prevX = curX, prevY = curY;
    function tick(now) {
      const dt = Math.min(48, now - prevTime);
      prevTime = now;

      // (a) anchor drift: gentle figure-8 around the right edge
      driftT += dt * 0.0007;
      const driftX = Math.sin(driftT * 1.0) * (isSmall ? 16 : 26);
      const driftY = Math.sin(driftT * 2.0) * (isSmall ? 14 : 22);

      // scroll-lag pulls Milo opposite scroll direction, bleeds away fast
      const lagY = Math.max(-70, Math.min(70, scrollVel * 0.9));
      scrollVel *= 0.86;

      let targetX = anchorX + driftX;
      let targetY = anchorY + driftY + lagY;

      // pointer attraction: drift toward cursor when within ~280px
      if (pointerActive) {
        const dx = pointerX - curX;
        const dy = pointerY - curY;
        const dist = Math.hypot(dx, dy);
        if (dist < 280 && dist > 40) {
          const pull = (1 - dist / 280) * 0.35;
          targetX += dx * pull;
          targetY += dy * pull;
        } else if (dist <= 40) {
          // shy: nudge away the last few pixels so we never overlap pointer
          targetX -= dx * 0.6;
          targetY -= dy * 0.6;
        }
      }

      // (b) wing-flutter: tiny fast wobble
      flutterPhase += dt * 0.022;
      const flutterY = Math.sin(flutterPhase * 4.0) * 1.6 + Math.sin(flutterPhase * 7.0) * 0.8;
      const flutterX = Math.cos(flutterPhase * 3.0) * 1.2;

      // critical-damp lerp toward target
      curX += (targetX - curX) * 0.10;
      curY += (targetY - curY) * 0.12;

      // tilt eases toward scroll target then decays
      tilt += (targetTilt - tilt) * 0.18;
      targetTilt *= 0.88;

      // pulse decay
      pulseScale += (1 - pulseScale) * 0.10;

      const renderX = curX + flutterX;
      const renderY = curY + flutterY;

      el.style.transform = `translate3d(${renderX.toFixed(2)}px, ${renderY.toFixed(2)}px, 0) rotate(${tilt.toFixed(2)}deg) scale(${pulseScale.toFixed(3)})`;

      // sparkle trail proportional to actual movement
      const moved = Math.hypot(renderX - prevX, renderY - prevY);
      if (moved > 0.6) emitSparkle(renderX, renderY, moved);
      prevX = renderX; prevY = renderY;

      renderSparkles(dt);
      requestAnimationFrame(tick);
    }
    if (!reduceMotion) {
      requestAnimationFrame(tick);
    } else {
      el.style.transform = `translate3d(${anchorX}px, ${anchorY}px, 0)`;
    }

    // ---- section-aware animation swap ----
    const sectionMap = {
      top:        'idle',
      about:      'wink',
      work:       'excited',
      experience: 'typing',
      skills:     'crazy',
      ai:         'heart',
    };
    const sections = Object.keys(sectionMap)
      .map(id => document.getElementById(id))
      .filter(Boolean);

    if ('IntersectionObserver' in window && sections.length) {
      const io = new IntersectionObserver((entries) => {
        let best = null;
        for (const e of entries) {
          if (e.isIntersecting && (!best || e.intersectionRatio > best.intersectionRatio)) best = e;
        }
        if (best) {
          const key = sectionMap[best.target.id];
          if (key) swap(key);
        }
      }, { threshold: [0.35, 0.6] });
      sections.forEach(s => io.observe(s));
    }

    // ---- click reaction: burst of sparkles + cycle reaction ----
    let clicks = 0;
    el.addEventListener('click', () => {
      clicks++;
      const reactions = ['heart', 'laughing', 'crazy', 'wink'];
      swap(reactions[clicks % reactions.length]);
      // confetti-ish burst
      for (let i = 0; i < 14; i++) {
        const ang = Math.random() * Math.PI * 2;
        const spd = 1 + Math.random() * 2.2;
        sparkles.push({
          x: curX, y: curY,
          vx: Math.cos(ang) * spd,
          vy: Math.sin(ang) * spd,
          life: 0,
          maxLife: 700 + Math.random() * 500,
          size: 1.4 + Math.random() * 1.8,
          hue: 188 + Math.random() * 50,
        });
      }
      setTimeout(() => {
        const y = window.scrollY + window.innerHeight / 2;
        let nearest = sections[0];
        let bestDist = Infinity;
        for (const s of sections) {
          const r = s.getBoundingClientRect();
          const mid = r.top + window.scrollY + r.height / 2;
          const d = Math.abs(mid - y);
          if (d < bestDist) { bestDist = d; nearest = s; }
        }
        if (nearest) swap(sectionMap[nearest.id] || 'idle');
      }, 2600);
    });

    // ---- end-of-page treat ----
    let firedEnd = false;
    window.addEventListener('scroll', () => {
      const nearBottom = window.innerHeight + window.scrollY >= document.body.offsetHeight - 80;
      if (nearBottom && !firedEnd) { firedEnd = true; swap('laughing'); }
      if (!nearBottom) firedEnd = false;
    }, { passive: true });
  }
</script>
