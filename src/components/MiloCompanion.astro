---
const animations = {
  idle:     '/milo/idle.lottie',
  wink:     '/milo/wink.lottie',
  excited:  '/milo/excited.lottie',
  typing:   '/milo/typing.lottie',
  crazy:    '/milo/crazy.lottie',
  heart:    '/milo/heart.lottie',
  laughing: '/milo/laughing.lottie',
};
---
<div
  id="milo-companion"
  class="milo-companion"
  role="img"
  aria-label="Milo: visit hellomilo.app"
  title="Visit hellomilo.app"
  data-anims={JSON.stringify(animations)}
>
  <div class="milo-shadow" aria-hidden="true"></div>
  <canvas id="milo-canvas" width="128" height="128"></canvas>
  <span class="milo-hint" aria-hidden="true">hellomilo.app</span>
</div>
<canvas id="milo-sparkles" aria-hidden="true"></canvas>

<style>
  .milo-companion {
    position: fixed;
    left: 0;
    top: 0;
    width: 72px;
    height: 72px;
    margin-left: -36px;
    margin-top: -36px;
    z-index: 40;
    pointer-events: auto;
    cursor: pointer;
    transform: translate3d(0, 0, 0);
    will-change: transform;
    filter: drop-shadow(0 6px 18px rgba(34, 211, 238, 0.22));
    transition: filter 220ms ease;
  }

  @media (max-width: 640px) {
    .milo-companion { width: 56px; height: 56px; margin-left: -28px; margin-top: -28px; }
  }

  .milo-companion canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  .milo-shadow {
    position: absolute;
    inset: -22% -22% -22% -22%;
    border-radius: 9999px;
    background: radial-gradient(closest-side, rgba(34,211,238,0.28), rgba(34,211,238,0) 70%);
    opacity: 0.9;
    pointer-events: none;
    animation: milo-breathe 3.6s ease-in-out infinite;
  }

  .milo-hint {
    position: absolute;
    left: 50%;
    bottom: -22px;
    transform: translateX(-50%);
    font-size: 9.5px;
    letter-spacing: 0.18em;
    text-transform: lowercase;
    color: rgba(186, 230, 253, 0.85);
    opacity: 0;
    transition: opacity 240ms ease, transform 240ms ease;
    pointer-events: none;
    white-space: nowrap;
    text-shadow: 0 1px 8px rgba(8, 47, 73, 0.7);
  }

  .milo-companion:hover .milo-hint { opacity: 1; transform: translate(-50%, -3px); }

  #milo-sparkles {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: 39;
  }

  @keyframes milo-breathe {
    0%, 100% { transform: scale(0.92); opacity: 0.55; }
    50%      { transform: scale(1.10); opacity: 0.95; }
  }

  @media (prefers-reduced-motion: reduce) {
    .milo-shadow { animation: none; }
    .milo-companion { transition: none; }
    #milo-sparkles { display: none; }
  }
</style>

<script type="module">
  import { DotLottie } from 'https://esm.sh/@lottiefiles/dotlottie-web@0.40.0';

  const el = document.getElementById('milo-companion');
  const canvas = document.getElementById('milo-canvas');
  const sparkleCanvas = document.getElementById('milo-sparkles');
  if (!el || !canvas) { /* bail */ } else {
    const anims = JSON.parse(el.dataset.anims);
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let player = new DotLottie({ canvas, src: anims.idle, loop: true, autoplay: true });

    let currentKey = 'idle';
    let switching = false;
    function swap(key) {
      if (!anims[key] || key === currentKey || switching) return;
      switching = true;
      currentKey = key;
      pulseScale = 1.22;
      try {
        player.load({ src: anims[key], loop: true, autoplay: true });
      } catch (e) {
        try { player.destroy(); } catch {}
        player = new DotLottie({ canvas, src: anims[key], loop: true, autoplay: true });
      }
      setTimeout(() => { switching = false; }, 320);
    }

    // ---- pixie motion model ----
    // Milo picks a fresh random spot every time the user scrolls past a
    // threshold and flies there with eased easing + arc. Between flights he
    // sits with a very slow gentle bob; no high-frequency vibration.
    const isSmall = window.matchMedia('(max-width: 640px)').matches;
    const edgePad = isSmall ? 36 : 56;
    const topPad = isSmall ? 80 : 110; // stay below nav
    const botPad = isSmall ? 80 : 96;

    let vw = window.innerWidth;
    let vh = window.innerHeight;

    // Half-size of Milo's bounding box plus a comfort margin, so the
    // collision test treats him as a circle a little larger than the canvas.
    const miloRadius = (isSmall ? 28 : 36) + 10;

    // Collect every text-bearing rect currently in the viewport. Cheap enough
    // to redo per teleport (<100 elements typical, sub-millisecond).
    const TEXT_SELECTOR = 'h1,h2,h3,h4,h5,h6,p,li,a,button,blockquote,figcaption,label,strong,em,span.gradient-text';
    function collectTextRects() {
      const rects = [];
      const nodes = document.querySelectorAll(TEXT_SELECTOR);
      for (const n of nodes) {
        // skip our own UI
        if (n.closest('#milo-companion')) continue;
        const r = n.getBoundingClientRect();
        // only rects with actual text content and visible in viewport
        if (r.width < 4 || r.height < 4) continue;
        if (r.bottom < 0 || r.top > vh || r.right < 0 || r.left > vw) continue;
        if (!n.textContent || !n.textContent.trim()) continue;
        rects.push(r);
      }
      return rects;
    }

    function spotHitsText(x, y, rects) {
      for (const r of rects) {
        // distance from point to rect; if <= miloRadius, collision
        const dx = Math.max(r.left - x, 0, x - r.right);
        const dy = Math.max(r.top - y, 0, y - r.bottom);
        if (dx * dx + dy * dy < miloRadius * miloRadius) return true;
      }
      return false;
    }

    function pickSpot(preferSide) {
      const rects = collectTextRects();
      // First try random spots biased to the preferred side; reject hits.
      for (let i = 0; i < 24; i++) {
        const sideBias = preferSide === 'left'
          ? Math.random() * 0.45
          : 0.55 + Math.random() * 0.45;
        const x = edgePad + miloRadius + sideBias * (vw - (edgePad + miloRadius) * 2);
        const y = topPad + Math.random() * (vh - topPad - botPad);
        if (!spotHitsText(x, y, rects)) return { x, y };
      }
      // Fallback: scan the side gutters (most likely empty zone outside
      // centered max-w content columns) for a clean point.
      const xs = preferSide === 'left'
        ? [edgePad + miloRadius, vw * 0.08, vw * 0.12]
        : [vw - edgePad - miloRadius, vw * 0.92, vw * 0.88];
      for (const x of xs) {
        for (let i = 0; i < 12; i++) {
          const y = topPad + Math.random() * (vh - topPad - botPad);
          if (!spotHitsText(x, y, rects)) return { x, y };
        }
      }
      // Last resort: top-right corner (always padded away from nav by topPad)
      return { x: vw - edgePad - miloRadius, y: topPad + 20 };
    }

    // current rendered position
    let curX = vw - edgePad;
    let curY = vh * 0.5;
    // start/end of current flight + timing
    let startX = curX, startY = curY;
    let targetX = curX, targetY = curY;
    let flightStart = 0;
    let flightDur = 0;
    let arcSign = 1; // alternates so arc bows up or down
    let lastSide = 'right';
    let bobPhase = Math.random() * Math.PI * 2;

    // scroll trigger: accumulate scroll delta, fire teleport when it crosses threshold
    let scrollAccum = 0;
    let lastScrollY = window.scrollY;
    let lastTeleportAt = 0;
    const SCROLL_THRESHOLD = isSmall ? 180 : 260; // px scrolled before re-pick
    const MIN_INTERVAL = 700; // ms minimum between flights, so fling-scrolls don't strobe

    let tilt = 0;
    let pulseScale = 1;

    function flyToNewSpot() {
      const now = performance.now();
      if (now - lastTeleportAt < MIN_INTERVAL) return;
      lastTeleportAt = now;
      lastSide = lastSide === 'right' ? 'left' : 'right';
      const spot = pickSpot(lastSide);
      // don't bother if the new spot is basically the same as current
      const dx = spot.x - curX, dy = spot.y - curY;
      const dist = Math.hypot(dx, dy);
      if (dist < 60) return;
      startX = curX; startY = curY;
      targetX = spot.x; targetY = spot.y;
      flightStart = now;
      // flight time scales with distance, bounded
      flightDur = Math.max(620, Math.min(1100, 380 + dist * 0.9));
      arcSign = (Math.random() < 0.5 ? -1 : 1);
      // tilt in the direction of flight
      tilt = Math.max(-18, Math.min(18, dx * 0.04));
    }

    function recompViewport() {
      vw = window.innerWidth;
      vh = window.innerHeight;
    }
    window.addEventListener('resize', recompViewport, { passive: true });

    window.addEventListener('scroll', () => {
      const now = window.scrollY;
      scrollAccum += Math.abs(now - lastScrollY);
      lastScrollY = now;
      if (scrollAccum >= SCROLL_THRESHOLD) {
        scrollAccum = 0;
        flyToNewSpot();
      }
    }, { passive: true });

    // ---- sparkle trail (canvas) ----
    let sctx = null;
    const sparkles = [];
    function sizeSparkles() {
      if (!sparkleCanvas) return;
      const dpr = Math.min(2, window.devicePixelRatio || 1);
      sparkleCanvas.width = Math.floor(window.innerWidth * dpr);
      sparkleCanvas.height = Math.floor(window.innerHeight * dpr);
      sparkleCanvas.style.width = window.innerWidth + 'px';
      sparkleCanvas.style.height = window.innerHeight + 'px';
      sctx = sparkleCanvas.getContext('2d');
      sctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    if (sparkleCanvas) {
      sizeSparkles();
      window.addEventListener('resize', sizeSparkles, { passive: true });
    }

    let lastSparkleAt = 0;
    function emitSparkle(x, y, speed) {
      const now = performance.now();
      // throttle: more sparkles when moving fast
      const interval = Math.max(36, 160 - speed * 12);
      if (now - lastSparkleAt < interval) return;
      lastSparkleAt = now;
      const count = 1 + Math.floor(Math.min(2, speed * 0.4));
      for (let i = 0; i < count; i++) {
        sparkles.push({
          x: x + (Math.random() - 0.5) * 14,
          y: y + (Math.random() - 0.5) * 14,
          vx: (Math.random() - 0.5) * 0.4,
          vy: (Math.random() - 0.5) * 0.4 + 0.15, // gently drift down
          life: 0,
          maxLife: 600 + Math.random() * 500, // ms
          size: 1.2 + Math.random() * 1.6,
          hue: 188 + Math.random() * 22, // cyan→teal range
        });
      }
    }

    function renderSparkles(dt) {
      if (!sctx) return;
      sctx.clearRect(0, 0, window.innerWidth, window.innerHeight);
      for (let i = sparkles.length - 1; i >= 0; i--) {
        const s = sparkles[i];
        s.life += dt;
        if (s.life >= s.maxLife) { sparkles.splice(i, 1); continue; }
        s.x += s.vx;
        s.y += s.vy;
        const t = s.life / s.maxLife;
        const alpha = (1 - t) * 0.55;
        const r = s.size * (1 - t * 0.4);
        sctx.beginPath();
        sctx.arc(s.x, s.y, r, 0, Math.PI * 2);
        sctx.fillStyle = `hsla(${s.hue}, 90%, 70%, ${alpha})`;
        sctx.shadowBlur = 8;
        sctx.shadowColor = `hsla(${s.hue}, 90%, 70%, ${alpha * 0.8})`;
        sctx.fill();
      }
      sctx.shadowBlur = 0;
    }

    // ---- main loop ----
    // easeInOutCubic for the flight curve
    function easeInOut(t) {
      return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
    }

    let prevTime = performance.now();
    let prevX = curX, prevY = curY;
    function tick(now) {
      const dt = Math.min(48, now - prevTime);
      prevTime = now;

      bobPhase += dt * 0.0018; // very slow

      const inFlight = now - flightStart < flightDur;
      if (inFlight) {
        const t = (now - flightStart) / flightDur;
        const e = easeInOut(t);
        // arc: bow perpendicular to the path so flight feels like a swoop, not a line
        const dx = targetX - startX;
        const dy = targetY - startY;
        const dist = Math.hypot(dx, dy) || 1;
        // perpendicular unit
        const px = -dy / dist;
        const py = dx / dist;
        const arcAmt = Math.sin(t * Math.PI) * Math.min(80, dist * 0.25) * arcSign;
        curX = startX + dx * e + px * arcAmt;
        curY = startY + dy * e + py * arcAmt;
        // tilt decays from launch tilt toward 0 over the flight
        tilt *= 0.96;
      } else {
        // settled: very gentle low-amplitude bob, not vibration
        const bobX = Math.sin(bobPhase * 0.9) * 3;
        const bobY = Math.sin(bobPhase * 1.3) * 4;
        // lerp toward target+bob so the settle is smooth
        const sx = targetX + bobX;
        const sy = targetY + bobY;
        curX += (sx - curX) * 0.06;
        curY += (sy - curY) * 0.06;
        tilt += (0 - tilt) * 0.08;
      }

      // pulse decay (used by swap() and click)
      pulseScale += (1 - pulseScale) * 0.10;

      el.style.transform = `translate3d(${curX.toFixed(2)}px, ${curY.toFixed(2)}px, 0) rotate(${tilt.toFixed(2)}deg) scale(${pulseScale.toFixed(3)})`;

      // sparkle trail only while in flight (settle is quiet)
      const moved = Math.hypot(curX - prevX, curY - prevY);
      if (inFlight && moved > 0.6) emitSparkle(curX, curY, moved);
      prevX = curX; prevY = curY;

      renderSparkles(dt);
      requestAnimationFrame(tick);
    }
    if (!reduceMotion) {
      // pick a tasteful starting spot
      const first = pickSpot('right');
      curX = startX = targetX = first.x;
      curY = startY = targetY = first.y;
      requestAnimationFrame(tick);
    } else {
      el.style.transform = `translate3d(${vw - edgePad}px, ${vh * 0.5}px, 0)`;
    }

    // ---- section-aware animation swap ----
    const sectionMap = {
      top:        'idle',
      about:      'wink',
      work:       'excited',
      experience: 'typing',
      skills:     'crazy',
      ai:         'heart',
    };
    const sections = Object.keys(sectionMap)
      .map(id => document.getElementById(id))
      .filter(Boolean);

    if ('IntersectionObserver' in window && sections.length) {
      const io = new IntersectionObserver((entries) => {
        let best = null;
        for (const e of entries) {
          if (e.isIntersecting && (!best || e.intersectionRatio > best.intersectionRatio)) best = e;
        }
        if (best) {
          const key = sectionMap[best.target.id];
          if (key) swap(key);
        }
      }, { threshold: [0.35, 0.6] });
      sections.forEach(s => io.observe(s));
    }

    // ---- click: heart-burst sparkles + open hellomilo.app ----
    el.addEventListener('click', (ev) => {
      ev.preventDefault();
      swap('heart');
      pulseScale = 1.28;
      // confetti-ish burst
      for (let i = 0; i < 18; i++) {
        const ang = Math.random() * Math.PI * 2;
        const spd = 1.2 + Math.random() * 2.4;
        sparkles.push({
          x: curX, y: curY,
          vx: Math.cos(ang) * spd,
          vy: Math.sin(ang) * spd,
          life: 0,
          maxLife: 700 + Math.random() * 500,
          size: 1.4 + Math.random() * 1.8,
          hue: 188 + Math.random() * 50,
        });
      }
      // give the burst a beat to register, then open
      setTimeout(() => {
        window.open('https://hellomilo.app', '_blank', 'noopener,noreferrer');
      }, 180);
    });

    // ---- end-of-page treat ----
    let firedEnd = false;
    window.addEventListener('scroll', () => {
      const nearBottom = window.innerHeight + window.scrollY >= document.body.offsetHeight - 80;
      if (nearBottom && !firedEnd) { firedEnd = true; swap('laughing'); }
      if (!nearBottom) firedEnd = false;
    }, { passive: true });
  }
</script>
