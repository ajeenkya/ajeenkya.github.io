---
import { site, stats } from '../data/site';
---
<section id="top" class="relative isolate overflow-hidden pt-40 pb-32">
  <div class="absolute inset-0 grid-bg" aria-hidden="true"></div>
  <div
    class="pointer-events-none absolute -top-40 left-1/2 h-[680px] w-[680px] -translate-x-1/2 rounded-full opacity-60 blur-3xl"
    style="background: radial-gradient(closest-side, rgba(34,211,238,0.22), transparent 70%);"
    data-parallax="-0.08"
    aria-hidden="true"
  ></div>
  <div class="relative mx-auto max-w-6xl px-6">
    <div class="reveal max-w-3xl">
      <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.02] px-3 py-1 text-xs uppercase tracking-[0.18em] text-mist-300">
        <span class="size-1.5 rounded-full bg-accent-400"></span> {site.location}
      </span>
      <h1 class="font-display mt-8 text-5xl font-semibold leading-[1.02] text-balance text-mist-100 sm:text-6xl md:text-7xl">
        <span class="gradient-text">AI engineer.</span><br />
        Technical founder.<br />
        Engineering leader.
      </h1>
      <p class="mt-8 max-w-2xl text-lg text-mist-300 text-pretty">
        {site.description}
      </p>
      <div class="mt-10 flex flex-wrap items-center gap-3">
        <a href="#contact" class="btn-primary">Get in touch</a>
        <a href={site.links.resume} class="btn-ghost" download>
          Download resume <span class="text-accent-400">↓</span>
        </a>
        <a href={site.links.github} class="btn-ghost" target="_blank" rel="noopener">GitHub</a>
        <a href={site.links.linkedin} class="btn-ghost" target="_blank" rel="noopener">LinkedIn</a>
      </div>
    </div>

    <div class="reveal mt-20 grid gap-4 sm:grid-cols-3">
      {stats.map((s) => (
        <div class="glass rounded-2xl p-6">
          <div class="font-display text-3xl font-semibold text-mist-100">{s.value}</div>
          <div class="mt-1 text-sm uppercase tracking-wider text-accent-400">{s.label}</div>
          <p class="mt-3 text-sm text-mist-300">{s.sub}</p>
        </div>
      ))}
    </div>
  </div>
</section>
