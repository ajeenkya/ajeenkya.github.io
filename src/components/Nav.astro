---
import { site } from '../data/site';
const links = [
  { href: '#about', label: 'About' },
  { href: '#work', label: 'Work' },
  { href: '#experience', label: 'Experience' },
  { href: '#skills', label: 'Skills' },
  { href: '#ai', label: 'AI Stack' },
  { href: '#contact', label: 'Contact' },
];
---
<header class="fixed inset-x-0 top-0 z-50">
  <div class="mx-auto max-w-6xl px-6 py-4">
    <nav class="glass flex items-center justify-between rounded-full px-5 py-3">
      <a href="#top" class="font-display text-sm font-semibold tracking-tight text-mist-100">
        {site.short}<span class="text-accent-400">.</span>
      </a>
      <ul class="hidden items-center gap-7 text-sm text-mist-300 md:flex">
        {links.map((l) => (
          <li>
            <a href={l.href} class="transition-colors hover:text-mist-100">{l.label}</a>
          </li>
        ))}
      </ul>
      <a href={site.links.resume} class="hidden text-sm font-medium text-mist-100 md:inline-flex" download>
        Resume <span class="ml-1 text-accent-400">↓</span>
      </a>
    </nav>
  </div>
</header>
