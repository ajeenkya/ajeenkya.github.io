---
import { site } from '../data/site';
const links = [
  { href: '#about', label: 'About' },
  { href: '#work', label: 'Work' },
  { href: '#experience', label: 'Experience' },
  { href: '#skills', label: 'Skills' },
  { href: '#looking', label: "What's next" },
  { href: '#contact', label: 'Contact' },
];
---
<header class="fixed inset-x-0 top-0 z-50" style="padding-top: env(safe-area-inset-top);">
  <div class="mx-auto max-w-6xl px-4 py-3 sm:px-6 sm:py-4">
    <nav class="glass flex items-center justify-between rounded-full px-4 py-2.5 sm:px-5 sm:py-3">
      <a href="#top" class="font-display text-sm font-semibold tracking-tight text-mist-100">
        {site.short}<span class="text-accent-400">.</span>
      </a>
      <ul class="hidden items-center gap-7 text-sm text-mist-300 md:flex">
        {links.map((l) => (
          <li>
            <a href={l.href} class="transition-colors hover:text-mist-100">{l.label}</a>
          </li>
        ))}
      </ul>
      <a href={site.links.resume} class="inline-flex items-center text-sm font-medium text-mist-100" download>
        Resume <span class="ml-1 text-accent-400">↓</span>
      </a>
    </nav>
  </div>
</header>
