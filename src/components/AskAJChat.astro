---
const apiUrl = import.meta.env.PUBLIC_CHAT_API_URL || '';
---
<button id="ask-aj-trigger" class="ask-aj-trigger" type="button" aria-haspopup="dialog" aria-controls="ask-aj-panel">
  <span class="ask-aj-trigger-dot" aria-hidden="true"></span>
  <span>Ask AJ</span>
</button>

<div id="ask-aj-panel" class="ask-aj-panel" role="dialog" aria-label="Chat with AJ-the-bot" aria-hidden="true" data-api={apiUrl}>
  <header class="ask-aj-head">
    <div class="ask-aj-head-meta">
      <span class="ask-aj-avatar" aria-hidden="true">aj</span>
      <div>
        <div class="ask-aj-name">AJ-the-bot</div>
        <div class="ask-aj-sub">AI proxy. The real AJ replies on email.</div>
      </div>
    </div>
    <button id="ask-aj-close" class="ask-aj-close" type="button" aria-label="Close chat">×</button>
  </header>

  <div id="ask-aj-thread" class="ask-aj-thread" aria-live="polite">
    <div class="ask-aj-msg is-bot">
      <div class="ask-aj-bubble">
        hi. i'm a small AI that knows AJ's work. ask me about Loadout, his Airbnb stack, what he's open to, or how to reach him.
      </div>
    </div>
    <div class="ask-aj-suggestions">
      <button class="ask-aj-chip" data-prompt="What is Loadout?">What is Loadout?</button>
      <button class="ask-aj-chip" data-prompt="What is AJ open to right now?">What is AJ open to?</button>
      <button class="ask-aj-chip" data-prompt="What did AJ build at Airbnb?">What did AJ build at Airbnb?</button>
      <button class="ask-aj-chip" data-prompt="How can I reach AJ?">How can I reach AJ?</button>
    </div>
  </div>

  <form id="ask-aj-form" class="ask-aj-form">
    <textarea id="ask-aj-input" class="ask-aj-input" rows="1" placeholder="ask anything about AJ..." maxlength="500" aria-label="Type a message"></textarea>
    <button type="submit" class="ask-aj-send" aria-label="Send">↑</button>
  </form>
  <div class="ask-aj-footnote">
    Replies are generated by Claude. Not the real AJ.
  </div>
</div>

<style>
  .ask-aj-trigger {
    position: fixed;
    bottom: clamp(1rem, 3vw, 1.75rem);
    left: clamp(1rem, 3vw, 1.75rem);
    z-index: 38;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px 10px 14px;
    border-radius: 9999px;
    border: 1px solid rgba(34, 211, 238, 0.35);
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.85), rgba(8, 47, 73, 0.85));
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: rgba(224, 242, 254, 0.96);
    font: inherit;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.01em;
    box-shadow: 0 12px 32px rgba(8, 47, 73, 0.45), 0 0 0 4px rgba(34, 211, 238, 0.06);
    cursor: pointer;
    transition: transform 180ms ease, box-shadow 220ms ease, background 220ms ease;
  }
  .ask-aj-trigger:hover {
    transform: translateY(-1px);
    box-shadow: 0 16px 36px rgba(8, 47, 73, 0.55), 0 0 0 6px rgba(34, 211, 238, 0.12);
  }
  .ask-aj-trigger-dot {
    width: 8px;
    height: 8px;
    border-radius: 9999px;
    background: rgb(34, 211, 238);
    box-shadow: 0 0 12px rgba(34, 211, 238, 0.8);
    animation: ask-aj-pulse 2.4s ease-in-out infinite;
  }
  @keyframes ask-aj-pulse {
    0%, 100% { opacity: 0.55; transform: scale(0.85); }
    50%      { opacity: 1;    transform: scale(1.15); }
  }
  body.ask-aj-open .ask-aj-trigger { display: none; }

  .ask-aj-panel {
    position: fixed;
    bottom: clamp(1rem, 3vw, 1.75rem);
    left: clamp(1rem, 3vw, 1.75rem);
    z-index: 60;
    width: min(380px, calc(100vw - 2rem));
    max-height: min(70vh, 640px);
    display: none;
    flex-direction: column;
    overflow: hidden;
    border-radius: 20px;
    border: 1px solid rgba(34, 211, 238, 0.28);
    background: linear-gradient(180deg, rgba(8, 14, 28, 0.96), rgba(8, 47, 73, 0.96));
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    box-shadow: 0 24px 56px rgba(2, 6, 23, 0.55), 0 0 0 6px rgba(34, 211, 238, 0.05);
    color: rgba(224, 242, 254, 0.95);
    font-size: 13px;
    line-height: 1.45;
  }
  body.ask-aj-open .ask-aj-panel { display: flex; }

  .ask-aj-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 14px 14px 12px 14px;
    border-bottom: 1px solid rgba(34, 211, 238, 0.14);
  }
  .ask-aj-head-meta { display: flex; align-items: center; gap: 10px; min-width: 0; }
  .ask-aj-avatar {
    width: 34px; height: 34px;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 9999px;
    background: linear-gradient(140deg, #22d3ee, #0891b2);
    color: #082f49;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: lowercase;
    flex: none;
  }
  .ask-aj-name { font-size: 13px; font-weight: 600; color: rgba(224, 242, 254, 0.98); }
  .ask-aj-sub  { font-size: 11px; color: rgba(186, 230, 253, 0.7); margin-top: 1px; }
  .ask-aj-close {
    width: 28px; height: 28px;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.04);
    color: rgba(224, 242, 254, 0.7);
    font-size: 18px; line-height: 1;
    border: 1px solid rgba(255, 255, 255, 0.06);
    cursor: pointer;
    transition: background 180ms ease, color 180ms ease;
  }
  .ask-aj-close:hover { background: rgba(255, 255, 255, 0.08); color: white; }

  .ask-aj-thread {
    flex: 1;
    overflow-y: auto;
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    scrollbar-width: thin;
    scrollbar-color: rgba(34, 211, 238, 0.3) transparent;
  }
  .ask-aj-thread::-webkit-scrollbar { width: 6px; }
  .ask-aj-thread::-webkit-scrollbar-thumb { background: rgba(34, 211, 238, 0.3); border-radius: 3px; }

  .ask-aj-msg { display: flex; max-width: 92%; }
  .ask-aj-msg.is-bot  { align-self: flex-start; }
  .ask-aj-msg.is-user { align-self: flex-end; }
  .ask-aj-bubble {
    padding: 9px 12px;
    border-radius: 14px;
    word-wrap: break-word;
    white-space: pre-wrap;
  }
  .ask-aj-msg.is-bot  .ask-aj-bubble {
    background: rgba(34, 211, 238, 0.08);
    border: 1px solid rgba(34, 211, 238, 0.18);
    color: rgba(224, 242, 254, 0.95);
    border-top-left-radius: 4px;
  }
  .ask-aj-msg.is-user .ask-aj-bubble {
    background: rgba(125, 211, 252, 0.18);
    border: 1px solid rgba(125, 211, 252, 0.28);
    color: white;
    border-top-right-radius: 4px;
  }
  .ask-aj-msg.is-bot.is-typing .ask-aj-bubble::after {
    content: '...';
    margin-left: 2px;
    opacity: 0.6;
    animation: ask-aj-typing 1.4s steps(3, end) infinite;
  }
  @keyframes ask-aj-typing {
    0%   { content: '.'; }
    33%  { content: '..'; }
    66%  { content: '...'; }
    100% { content: '.'; }
  }

  .ask-aj-suggestions {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 4px;
  }
  .ask-aj-chip {
    padding: 6px 10px;
    border-radius: 9999px;
    border: 1px solid rgba(34, 211, 238, 0.25);
    background: rgba(34, 211, 238, 0.05);
    color: rgba(186, 230, 253, 0.9);
    font: inherit;
    font-size: 11.5px;
    cursor: pointer;
    transition: background 180ms ease, color 180ms ease, border-color 180ms ease;
  }
  .ask-aj-chip:hover {
    background: rgba(34, 211, 238, 0.12);
    color: white;
    border-color: rgba(34, 211, 238, 0.4);
  }

  .ask-aj-form {
    display: flex;
    align-items: flex-end;
    gap: 8px;
    padding: 10px 12px;
    border-top: 1px solid rgba(34, 211, 238, 0.14);
  }
  .ask-aj-input {
    flex: 1;
    resize: none;
    max-height: 96px;
    padding: 8px 10px;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    color: white;
    font: inherit;
    font-size: 13px;
    line-height: 1.4;
    outline: none;
    transition: border-color 160ms ease, background 160ms ease;
  }
  .ask-aj-input:focus { border-color: rgba(34, 211, 238, 0.4); background: rgba(255, 255, 255, 0.05); }
  .ask-aj-input::placeholder { color: rgba(186, 230, 253, 0.5); }

  .ask-aj-send {
    width: 36px; height: 36px;
    flex: none;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 9999px;
    border: none;
    background: linear-gradient(140deg, #22d3ee, #0891b2);
    color: #082f49;
    font-size: 16px; font-weight: 700;
    cursor: pointer;
    box-shadow: 0 6px 16px rgba(34, 211, 238, 0.35);
    transition: transform 160ms ease, box-shadow 160ms ease, opacity 160ms ease;
  }
  .ask-aj-send:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(34, 211, 238, 0.5); }
  .ask-aj-send:disabled { opacity: 0.45; cursor: not-allowed; transform: none; box-shadow: none; }

  .ask-aj-footnote {
    padding: 0 14px 10px 14px;
    font-size: 10px;
    color: rgba(186, 230, 253, 0.45);
    text-align: center;
  }

  @media (max-width: 480px) {
    .ask-aj-trigger { bottom: 0.75rem; left: 0.75rem; padding: 9px 14px 9px 12px; font-size: 12.5px; }
    .ask-aj-panel { width: calc(100vw - 1rem); left: 0.5rem; bottom: 0.5rem; max-height: 78vh; }
  }
</style>

<script type="module">
  const trigger = document.getElementById('ask-aj-trigger');
  const panel   = document.getElementById('ask-aj-panel');
  const closeBtn= document.getElementById('ask-aj-close');
  const thread  = document.getElementById('ask-aj-thread');
  const form    = document.getElementById('ask-aj-form');
  const input   = document.getElementById('ask-aj-input');
  const sendBtn = form?.querySelector('.ask-aj-send');

  if (!trigger || !panel || !thread || !form || !input || !sendBtn) {
    // bail silently
  } else {
    const API_URL = panel.dataset.api || '';
    const STORAGE_KEY = 'ask_aj_thread_v1';
    let messages = []; // {role: 'user'|'assistant', content: string}
    let streaming = false;

    // restore prior session
    try {
      const saved = JSON.parse(sessionStorage.getItem(STORAGE_KEY) || '[]');
      if (Array.isArray(saved) && saved.length) {
        messages = saved;
        renderHistory();
      }
    } catch {}

    function open() {
      document.body.classList.add('ask-aj-open');
      panel.setAttribute('aria-hidden', 'false');
      setTimeout(() => input.focus(), 50);
    }
    function close() {
      document.body.classList.remove('ask-aj-open');
      panel.setAttribute('aria-hidden', 'true');
    }
    trigger.addEventListener('click', open);
    closeBtn?.addEventListener('click', close);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && document.body.classList.contains('ask-aj-open')) close();
    });

    // chips
    thread.querySelectorAll('.ask-aj-chip').forEach(chip => {
      chip.addEventListener('click', () => {
        const prompt = chip.getAttribute('data-prompt') || chip.textContent || '';
        input.value = prompt;
        form.requestSubmit();
      });
    });

    // textarea auto-grow + Enter to send (Shift+Enter for newline)
    input.addEventListener('input', () => {
      input.style.height = 'auto';
      input.style.height = Math.min(96, input.scrollHeight) + 'px';
    });
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        form.requestSubmit();
      }
    });

    function persist() {
      try { sessionStorage.setItem(STORAGE_KEY, JSON.stringify(messages.slice(-16))); } catch {}
    }
    function addMessageNode(role, text) {
      const wrap = document.createElement('div');
      wrap.className = 'ask-aj-msg ' + (role === 'user' ? 'is-user' : 'is-bot');
      const b = document.createElement('div');
      b.className = 'ask-aj-bubble';
      b.textContent = text;
      wrap.appendChild(b);
      thread.appendChild(wrap);
      thread.scrollTop = thread.scrollHeight;
      return b;
    }
    function renderHistory() {
      // wipe everything except the very first welcome message + suggestions
      const welcome = thread.querySelector('.ask-aj-msg.is-bot');
      const sugg    = thread.querySelector('.ask-aj-suggestions');
      thread.innerHTML = '';
      if (welcome) thread.appendChild(welcome);
      if (sugg)    thread.appendChild(sugg);
      for (const m of messages) addMessageNode(m.role, m.content);
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (streaming) return;
      const text = input.value.trim();
      if (!text) return;

      input.value = '';
      input.style.height = 'auto';

      messages.push({ role: 'user', content: text });
      addMessageNode('user', text);
      persist();

      if (!API_URL) {
        const node = addMessageNode('assistant', '');
        node.parentElement.classList.add('is-typing');
        node.textContent = 'Chat backend not wired yet. Deploy worker/ and set PUBLIC_CHAT_API_URL. See worker/README.md.';
        node.parentElement.classList.remove('is-typing');
        messages.push({ role: 'assistant', content: node.textContent });
        persist();
        return;
      }

      // assistant bubble that we stream into
      const node = addMessageNode('assistant', '');
      node.parentElement.classList.add('is-typing');
      streaming = true;
      sendBtn.disabled = true;

      let full = '';
      try {
        const res = await fetch(API_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages }),
        });
        if (!res.ok || !res.body) {
          throw new Error('upstream ' + res.status);
        }

        // parse Anthropic SSE stream
        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let buffer = '';
        while (true) {
          const { value, done } = await reader.read();
          if (done) break;
          buffer += decoder.decode(value, { stream: true });
          const lines = buffer.split('\n');
          buffer = lines.pop() || '';
          for (const line of lines) {
            if (!line.startsWith('data:')) continue;
            const data = line.slice(5).trim();
            if (!data || data === '[DONE]') continue;
            try {
              const evt = JSON.parse(data);
              if (evt.type === 'content_block_delta' && evt.delta?.type === 'text_delta') {
                full += evt.delta.text;
                node.textContent = full;
                node.parentElement.classList.remove('is-typing');
                thread.scrollTop = thread.scrollHeight;
              }
            } catch { /* ignore partial */ }
          }
        }
      } catch (err) {
        node.textContent = full || 'Something went wrong reaching the chat backend. Try again in a moment.';
        node.parentElement.classList.remove('is-typing');
      } finally {
        if (full) messages.push({ role: 'assistant', content: full });
        persist();
        streaming = false;
        sendBtn.disabled = false;
        input.focus();
      }
    });
  }
</script>
