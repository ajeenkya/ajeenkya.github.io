---
import SectionHeader from './SectionHeader.astro';
import { lookingFor } from '../data/site';
---
<section id="looking" class="relative py-32">
  <div class="absolute inset-x-0 top-1/2 -z-10 mx-auto h-[360px] max-w-3xl -translate-y-1/2 rounded-full opacity-40 blur-3xl"
    style="background: radial-gradient(closest-side, rgba(34,211,238,0.18), transparent 70%);"
    aria-hidden="true"
  ></div>
  <div class="mx-auto max-w-6xl px-6">
    <SectionHeader
      eyebrow="What's next"
      title="Roles I'm built for"
      lede="Founding-team seats at AI-native startups and venture studios. Bias toward operators who can ship product-grade systems and run small teams from day one."
    />
    <div class="mt-16 grid gap-4 md:grid-cols-2">
      {lookingFor.map((r) => (
        <div class="reveal glass rounded-2xl p-7">
          <div class="font-display text-lg font-semibold text-mist-100">{r.role}</div>
          <p class="mt-3 text-mist-300">{r.fit}</p>
        </div>
      ))}
    </div>
  </div>
</section>
